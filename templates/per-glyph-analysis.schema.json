{
  "type": "object",
  "required": [
    "crop_id",
    "page_location",
    "character",
    "confidence",
    "layout",
    "structure",
    "stroke_quality",
    "overall_assessment",
    "advice",
    "quality_class",
    "strengths",
    "issues"
  ],
  "properties": {
    "crop_id": {
      "type": "string"
    },
    "page_location": {
      "type": "string"
    },
    "character": {
      "type": "string"
    },
    "exemplar_crop_id": {
      "type": ["string", "null"]
    },
    "score": {
      "type": ["number", "null"],
      "minimum": 1,
      "maximum": 5
    },
    "quality_class": {
      "type": "string",
      "enum": ["strong", "good", "usable", "needs_work", "weak"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "layout": {
      "type": "string"
    },
    "structure": {
      "type": "string"
    },
    "stroke_quality": {
      "type": "string"
    },
    "exemplar_deviation": {
      "type": ["string", "null"]
    },
    "overall_assessment": {
      "type": "string"
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description", "severity"],
        "properties": {
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "advice": {
      "type": "string"
    },
    "evidence_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stroke_segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stroke_name", "points"],
        "properties": {
          "stroke_name": {
            "type": "string"
          },
          "stroke_type": {
            "type": "string",
            "enum": ["horizontal", "vertical", "left_falling", "right_falling", "dot", "hook", "turn", "curve", "other"]
          },
          "points": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "number"
              }
            }
          },
          "length_px": {
            "type": "number"
          },
          "angle_degrees": {
            "type": "number"
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
